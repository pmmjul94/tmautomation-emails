# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Zoho (single set of creds covers CRM + Campaigns via same OAuth app)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
# Zoho data center: com | eu | in | com.au | jp
ZOHO_DC=com
# Name of the Zoho CRM custom field holding the industry value
ZOHO_INDUSTRY_FIELD=Industry
# Zoho Campaigns "From" details
ZOHO_FROM_EMAIL=
ZOHO_FROM_NAME=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_BUCKET=email-assets

# Reviewers who get the "test" email for approval before real send
# Comma-separated. Leave unset to use the defaults (wais@textmunication.com, ab@caazllc.com).
TEST_RECIPIENTS=wais@textmunication.com,ab@caazllc.com

# Public site URL — used to build the approval link inside test emails.
# On Vercel this is auto-populated via VERCEL_URL; set manually if you have a custom domain.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Cron protection (Vercel sets this automatically; set it locally if you hit the endpoint directly)
CRON_SECRET=choose-a-long-random-string
